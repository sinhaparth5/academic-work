{{ printf "<?xml version=\"1.0\" encoding=\"utf-8\" standalone=\"yes\"?>" | safeHTML }}
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
  {{- range .Data.Pages }}
  {{- if not .Params.noindex }}
  <url>
    <loc>{{ .Permalink }}</loc>
    {{- if not .Lastmod.IsZero }}
    <lastmod>{{ .Lastmod.Format "2006-01-02T15:04:05-07:00" | safeHTML }}</lastmod>
    {{- end }}
    <changefreq>{{- if eq .Kind "home" }}daily{{- else if eq .Kind "section" }}weekly{{- else }}monthly{{- end }}</changefreq>
    <priority>{{- if eq .Kind "home" }}1.0{{- else if eq .Kind "section" }}0.8{{- else if or (eq .Kind "taxonomy") (eq .Kind "term") }}0.4{{- else }}0.6{{- end }}</priority>
  </url>
  {{- end }}
  {{- end }}
</urlset>
