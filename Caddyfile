{
	admin off
	auto_https off
}

:8081 {
	root * /srv

	encode zstd gzip

	file_server

	header {
		# Restrict framing
		X-Frame-Options "DENY"
		# Prevent MIME sniffing
		X-Content-Type-Options "nosniff"
		# Referrer policy
		Referrer-Policy "strict-origin-when-cross-origin"
		# Disable browser features not needed on a static site
		Permissions-Policy "camera=(), microphone=(), geolocation=(), payment=(), usb=(), interest-cohort=()"
		# XSS protection (legacy browsers)
		X-XSS-Protection "1; mode=block"
		# Remove server fingerprint
		-Server

		# Content Security Policy
		# - Google Tag Manager and Google Analytics are used for analytics.
		# - MathSnap assets are loaded from jsDelivr on pages that opt into math.
		# - unsafe-inline on style-src is kept for third-party math rendering styles.
		Content-Security-Policy "default-src 'none'; script-src 'self' 'unsafe-inline' https://www.googletagmanager.com https://sinhaparth5.github.io https://cdn.jsdelivr.net; style-src 'self' 'unsafe-inline' https://sinhaparth5.github.io https://cdn.jsdelivr.net; font-src 'self' https://sinhaparth5.github.io; img-src 'self' data: https://www.googletagmanager.com https://www.google-analytics.com https://sinhaparth5.github.io; frame-src https://www.googletagmanager.com; manifest-src 'self'; connect-src 'self' https://www.google-analytics.com https://region1.google-analytics.com; frame-ancestors 'none'; base-uri 'self'; form-action 'none'"
	}

	# Fingerprinted CSS and JS are immutable
	header /css/* Cache-Control "public, max-age=31536000, immutable"
	header /js/*  Cache-Control "public, max-age=31536000, immutable"

	# Fingerprinted or versioned static assets are immutable
	header /images/* Cache-Control "public, max-age=604800"
	header /icons/*  Cache-Control "public, max-age=604800"
	header /fonts/*  Cache-Control "public, max-age=31536000, immutable"

	# XSL, manifest, and feed cached for 1 hour
	header /*.xsl       Cache-Control "public, max-age=3600"
	header /*.webmanifest Cache-Control "public, max-age=3600"
	header /site.webmanifest Cache-Control "public, max-age=3600"
	header /*.webmanifest Content-Type "application/manifest+json; charset=utf-8"
	header /site.webmanifest Content-Type "application/manifest+json; charset=utf-8"
	header /index.xml   Cache-Control "public, max-age=3600"

	@fonts {
		path *.woff *.woff2 *.ttf *.otf *.eot
	}
	header @fonts Access-Control-Allow-Origin "*"

	handle_errors {
		rewrite * /404.html
		file_server
	}
}
