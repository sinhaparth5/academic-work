{
	admin off
	auto_https off
}

:8081 {
	root * /srv

	encode zstd gzip

	file_server

	# ── Security headers ──────────────────────────────────────
	header {
		# Restrict framing
		X-Frame-Options "DENY"
		# Prevent MIME sniffing
		X-Content-Type-Options "nosniff"
		# Referrer policy
		Referrer-Policy "strict-origin-when-cross-origin"
		# Disable browser features not needed on a static site
		Permissions-Policy "camera=(), microphone=(), geolocation=(), payment=(), usb=(), interest-cohort=()"
		# XSS protection (legacy browsers)
		X-XSS-Protection "1; mode=block"
		# Remove server fingerprint
		-Server

		# Content Security Policy
		# - Google Fonts for Source Serif 4
		# - jsDelivr for KaTeX CSS + JS
		# - unsafe-inline on script-src required for KaTeX onload= attribute
		Content-Security-Policy "default-src 'none'; script-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net; style-src 'self' https://fonts.googleapis.com https://cdn.jsdelivr.net; font-src 'self' https://fonts.gstatic.com; img-src 'self' data:; manifest-src 'self'; connect-src 'self'; frame-ancestors 'none'; base-uri 'self'; form-action 'none'"
	}

	# ── Cache headers ─────────────────────────────────────────
	# Fingerprinted CSS and JS are immutable
	header /css/* Cache-Control "public, max-age=31536000, immutable"
	header /js/*  Cache-Control "public, max-age=31536000, immutable"

	# Images and fonts cached for 1 week
	header /images/* Cache-Control "public, max-age=604800"
	header /icons/*  Cache-Control "public, max-age=604800"

	# XSL, manifest, and feed cached for 1 hour
	header /*.xsl       Cache-Control "public, max-age=3600"
	header /*.webmanifest Cache-Control "public, max-age=3600"
	header /index.xml   Cache-Control "public, max-age=3600"

	# ── CORS for fonts ────────────────────────────────────────
	@fonts {
		path *.woff *.woff2 *.ttf *.otf *.eot
	}
	header @fonts Access-Control-Allow-Origin "*"

	# ── 404 handling ─────────────────────────────────────────
	handle_errors {
		rewrite * /404.html
		file_server
	}
}
